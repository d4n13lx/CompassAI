{
  "name": "career-compass",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:fresh": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "prisma generate && tsc --noEmit",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "merge:knowledge": "node scripts/merge-perguntas-into-knowledge.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.3.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.6.4",
    "next": "^15.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.3",
    "postcss": "^8.5.3",
    "prisma": "^6.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  }
}
